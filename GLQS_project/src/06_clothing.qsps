	end
	if $ARGS[1] = 'materinstvo':
		gs 'mod_GLQS_main', 'fill_clo', 'materinstvo_dress'
	end
	if $ARGS[1] = 'moncheri':
		gs 'mod_GLQS_main', 'fill_clo', 'moncheri_dress'
