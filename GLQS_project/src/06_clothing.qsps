		gs 'mod_GLQS_main', 'fill_shoe', 'scandalicious'
		gs 'mod_GLQS_main', 'fill_body', 'scandalicious'
	end
	if $ARGS[1] = 'eroto':
		gs 'mod_GLQS_main', 'fill_clo', 'eroto_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'eroto_dress'
		gs 'mod_GLQS_main', 'fill_clo', 'eroto_strip'
		gs 'mod_GLQS_main', 'fill_shoe', 'eroto'
		gs 'mod_GLQS_main', 'fill_bra', 'eroto'
		gs 'mod_GLQS_main', 'fill_panty', 'eroto'
	end
	if $ARGS[1] = 'lusso':
		gs 'mod_GLQS_main', 'fill_bra', 'lusso'
