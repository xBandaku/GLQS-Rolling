		gs 'mod_GLQS_main', 'fill_body', 'moncheri'
		gs 'mod_GLQS_main', 'fill_coat', 'moncheri'
		gs 'mod_GLQS_main', 'fill_purse', 'moncheri'
	end
	if $ARGS[1] = 'nerdvana':
		gs 'mod_GLQS_main', 'fill_clo', 'nerdvana_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'nerdvana_cosplay'
		gs 'mod_GLQS_main', 'fill_clo', 'nerdvana_swimsuit'
		gs 'mod_GLQS_main', 'fill_clo', 'nerdvana_bikinis'
		gs 'mod_GLQS_main', 'fill_purse', 'nerdvana'
	end
	if $ARGS[1] = 'scandalicious':
		gs 'mod_GLQS_main', 'fill_clo', 'scandalicious_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'scandalicious_dress'
