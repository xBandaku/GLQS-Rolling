		gs 'mod_GLQS_main', 'fill_coat', 'dolls'
		gs 'mod_GLQS_main', 'fill_purse', 'dolls'
	end
	if $ARGS[1] = 'fancy':
		gs 'mod_GLQS_main', 'fill_clo', 'fancy_burlesque'
	end
	if $ARGS[1] = 'fashionista':
		gs 'mod_GLQS_main', 'fill_clo', 'fashionista_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'fashionista_dress'
		gs 'mod_GLQS_main', 'fill_bra', 'fashionista'
		gs 'mod_GLQS_main', 'fill_panty', 'fashionista'
		gs 'mod_GLQS_main', 'fill_purse', 'fashionista'
	end
	if $ARGS[1] = 'flamingos':
		gs 'mod_GLQS_main', 'fill_clo', 'flamingos_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'flamingos_dress'
		gs 'mod_GLQS_main', 'fill_purse', 'flamingos'
	end
	if $ARGS[1] = 'salacious':
		gs 'mod_GLQS_main', 'fill_clo', 'salacious_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'salacious_dress'
		gs 'mod_GLQS_main', 'fill_bra', 'salacious'
		gs 'mod_GLQS_main', 'fill_panty', 'salacious'
		gs 'mod_GLQS_main', 'fill_body', 'salacious'
	end
	if $ARGS[1] = 'gm':
		gs 'mod_GLQS_main', 'fill_clo', 'gm_outfits'
		gs 'mod_GLQS_main', 'fill_clo', 'gm_dress'
		gs 'mod_GLQS_main', 'fill_clo', 'gm_office'
		gs 'mod_GLQS_main', 'fill_clo', 'gm_maid'
		gs 'mod_GLQS_main', 'fill_clo', 'gm_server'
		gs 'mod_GLQS_main', 'fill_clo', 'gm_school'
		gs 'mod_GLQS_main', 'fill_shoe', 'gm'
		gs 'mod_GLQS_main', 'fill_bra', 'gm'
		gs 'mod_GLQS_main', 'fill_panty', 'gm'
		gs 'mod_GLQS_main', 'fill_coat', 'gm'
		gs 'mod_GLQS_main', 'fill_purse', 'gm'
	end
	if $ARGS[1] = 'market':
