	act 'Market': gs 'mod_GLQS_main', 'store_buy', 'market' & gt 'mod_GLQS_main', 'store_menu'
	act 'Materinstvo': gs 'mod_GLQS_main', 'store_buy', 'materinstvo' & gt 'mod_GLQS_main', 'store_menu'
