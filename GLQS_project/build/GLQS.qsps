	'<center><b><font color="maroon">Piercing Jewelry: <<$glqs_slot>></font></b></center>'
	'<br><<total>> designs available. Click an image to apply it.'
	*nl
	$glqs_grid = '<div style="display:flex; flex-wrap:wrap; gap:8px;">'
	glqs_i = 1
	:glqs_pierce_img_loop
	if glqs_i <= total:
		$glqs_grid += '<div style="flex:0 0 auto;"><a href="exec: gs ''piercing_management'', ''add'', ''<<$glqs_slot>>'', <<glqs_i>> & gs ''stat'' & gt ''mod_GLQS_main'', ''piercing_design_menu'', ''<<$glqs_slot>>''"><img height="220" src="<<func(''piercing_management'', $glqs_slot + ''_image'', glqs_i)>>"></a></div>'
		glqs_i += 1
		jump 'glqs_pierce_img_loop'
	end
	killvar 'glqs_i'
	$glqs_grid += '</div>'
	$glqs_grid
	*nl

	if pcs_piercings[$glqs_slot] > 0:
