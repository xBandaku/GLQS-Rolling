!! ===== FILL HELPERS =====
!! Each helper sets the item owned flag AND repairs it to full durability by
!! setting the companion _h[] array to max strength (matches what the games
!! own cheat_repair functions do, so items never need tailor repair/resize.

!! FILL HELPERS: per-category item granting loops
if $ARGS[0] = 'fill_clo':
	gs 'clothing', 'totals', $ARGS[1]
	glqs_i = 1
	:glqs_clo_loop
	if glqs_i <= total:
		dyneval('<<$ARGS[1]>>[glqs_i] = 1')
		gs 'clothing_attributes', $ARGS[1], glqs_i
		dyneval('<<$ARGS[1]>>_h[glqs_i] = CloMaxStrength')
		glqs_i += 1
		jump 'glqs_clo_loop'
	end
	killvar 'glqs_i'
end

if $ARGS[0] = 'fill_shoe':
	gs 'shoes', 'totals', $ARGS[1] + '_shoe'
	glqs_i = 1
	:glqs_shoe_loop
	if glqs_i <= total:
		dyneval('<<$ARGS[1]>>_shoe[glqs_i] = 1')
		gs 'shoe_attributes', $ARGS[1], glqs_i
		dyneval('<<$ARGS[1]>>_shoe_h[glqs_i] = ShoMaxStrength')
		glqs_i += 1
		jump 'glqs_shoe_loop'
	end
	killvar 'glqs_i'
end

if $ARGS[0] = 'fill_bra':
	gs 'bras', 'totals', $ARGS[1] + '_bras'
	glqs_i = 1
	:glqs_bra_loop
	if glqs_i <= total:
		dyneval('<<$ARGS[1]>>_bras[glqs_i] = 1')
