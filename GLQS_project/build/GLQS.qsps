!! SKILLS & ATTRIBUTES SUBMENU
if $ARGS[0] = 'stats_menu':
	menu_off = 0
	usehtml = 1
	$location_type = 'event'
	gs 'stat'
	gs 'themes', 'indoors'
	'<center><b><font color="maroon">Skills & Attributes</font></b></center>'
	*nl
	$glqs_tbl = ''
	$glqs_tbl += '<table width="80%" cellpadding=4>'
	$glqs_tbl += '<tr><td><b>Attributes</b></td><td></td></tr>'
	$glqs_tbl += '<tr><td>Strength</td><td><<stren_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Agility</td><td><<agil_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Endurance</td><td><<vital_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Intelligence</td><td><<intel_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Reaction</td><td><<react_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Spirit</td><td><<sprt_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Charisma</td><td><<chrsm_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Perception</td><td><<prcptn_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Magic</td><td><<magik_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Inhibition (0=uninhibited)</td><td><<inhib_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Willpower max</td><td><<willpowermax>></td></tr>'
	$glqs_tbl += '<tr><td><b>Skills (visible level)</b></td><td></td></tr>'
	$glqs_tbl += '<tr><td>People Skills</td><td><<humint_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Persuasion</td><td><<persuas_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Observation</td><td><<observ_lvl>></td></tr>'
	$glqs_tbl += '<tr><td>Jabs</td><td><<jab_lvl>></td></tr>'
